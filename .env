# ParaForm Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project credentials (needed for auth only — not for model fetching)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Base URL of your Supabase public storage bucket
# This is where catalog.json and all .scad files live.
# Example: https://abcdefg.supabase.co/storage/v1/object/public/models
VITE_BUCKET_BASE_URL=
